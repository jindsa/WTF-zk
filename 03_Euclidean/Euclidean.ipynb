     "text": [
      "The greatest common divisor of 30 and 100 is 10\n"
     ]
    }
   ],
   "source": [
    "# 欧几里得算法 求最大公约数\n",
    "\n",
    "def euclidean_algorithm(a,b):\n",
    "    if a < b:\n",
    "        a, b = b, a\n",
    "    while b:\n",
    "        a, b = b, a % b\n",
    "\n",
    "    return a \n",
    "# Example\n",
    "a = 30\n",
    "b = 100\n",
    "gcd_result = euclidean_algorithm(a, b)\n",
    "print(f'The greatest common divisor of {a} and {b} is {gcd_result}')"
   ]
  }
 ],
